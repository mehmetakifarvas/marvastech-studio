#include <avr/io.h>
#include <util/delay.h>

#define LED_PIN 5 //Arduino dijital 13 = PortB, Pin5

int main(void)
{
    
    DDRB |= (1 << LED_PIN);

    while (1) 
    {
   
        PORTB |= (1 << LED_PIN);
        _delay_ms(500);

        PORTB &= ~(1 << LED_PIN);
        _delay_ms(500);
    }

    return 0; 
}




